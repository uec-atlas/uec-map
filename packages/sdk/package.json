{
  "name": "@uec-atlas/uec-map-sdk",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/main.js",
  "module": "./dist/main.mjs",
  "types": "./dist/main.d.ts",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/main.mjs",
      "require": "./dist/main.js"
    },
    "./style.css": "./dist/style.css"
  },
  "scripts": {
    "dev": "vite build --watch --mode esm",
    "build:esm": "vite build --mode esm",
    "build:umd": "vite build --mode umd",
    "build": "pnpm build:esm && pnpm build:umd"
  },
  "peerDependencies": {
    "maplibre-gl": "^5"
  },
  "dependencies": {
    "pmtiles": "^4.4.1"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "maplibre-gl": "^5.24.0",
    "vite": "^8.1.0",
    "vite-plugin-dts": "^5.0.3",
    "vite-plugin-static-copy": "^4.1.1"
  }
}
